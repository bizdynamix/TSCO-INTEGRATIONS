# ============================================================================
# REQUIRED: Monday.com API
# ============================================================================

# Your Monday.com API token
# Get from: Monday.com → Account → API token
MONDAY_API_TOKEN=your_monday_api_token_here

# ============================================================================
# REQUIRED: Microsoft Azure AD (Entra ID) / SharePoint
# ============================================================================

# Azure AD Tenant ID
# Find in: Azure Portal → Azure Active Directory → Overview → Tenant ID
TENANT_ID=your_tenant_id_here

# Azure AD App Registration → Client ID
# Find in: Azure Portal → App registrations → [Your App] → Application (client) ID
CLIENT_ID=your_client_id_here

# Azure AD App Registration → Client Secret
# Find in: Azure Portal → App registrations → [Your App] → Certificates & secrets
# ⚠️ NEVER commit this to Git!
CLIENT_SECRET=your_client_secret_here

# ============================================================================
# OPTIONAL: SharePoint Configuration
# ============================================================================

# SharePoint hostname (default: seedcompany.sharepoint.com)
SHAREPOINT_HOSTNAME=seedcompany.sharepoint.com

# SharePoint site path (default: /sites/ActiveProjects)
SHAREPOINT_SITE_PATH=/sites/ActiveProjects

# Legacy: Test upload folder (used by bulk_migrate_all.py only)
TEST_UPLOAD_FOLDER=Projects/_TEST_MondayUpload

# ============================================================================
# OPTIONAL: Flask Webhook Server
# ============================================================================

# Flask server port (default: 5000)
FLASK_PORT=5000

# Flask server host (default: 0.0.0.0 for all interfaces)
# Use 127.0.0.1 for localhost only (development)
FLASK_HOST=0.0.0.0

# ============================================================================
# WEBHOOK SETUP NOTES
# ============================================================================
#
# Monday Board ID: 8445065255
# Webhook Endpoint: POST /sync-language-profile
#
# Expected Columns:
#   - Item Name (Text) → Project name
#   - Project Status (Status/Dropdown) → with "Active" value
#   - Language Profile (File) → PDF/Word document
#   - FPM (Person/User) → Language Project Manager
#   - MOU End Date (Date) → optional metadata
#   - Updates (Updates) → for @mention notifications
#
# Workflow:
#   1. Monday Vibe automation triggers on Status = "Active"
#   2. Checks if Language Profile file exists
#   3. If yes → calls webhook → file syncs to SharePoint
#   4. If no → creates UPDATE with @FPM notification
#
# See: monday_automation_setup.md for full Vibe configuration guide
# See: webhook_handler.py for implementation details
