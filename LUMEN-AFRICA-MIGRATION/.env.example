# SC US Instance (Seed Company)
MONDAY_API_TOKEN_US=<your-sc-us-api-token>

# Lumen Africa EU Instance
MONDAY_API_TOKEN_EU=<your-lumen-africa-eu-token>
MONDAY_WORKSPACE_ID_EU=<lumen-africa-eu-workspace-id>
MONDAY_TEAM_ID_EU=<lumen-africa-eu-team-id>

# Migration Options
PRESERVE_HISTORY=true
PRESERVE_AUTOMATIONS=false
PRESERVE_ATTACHMENTS=true
DRY_RUN=true

# Logging
LOG_LEVEL=debug
OUTPUT_DIR=./reports
